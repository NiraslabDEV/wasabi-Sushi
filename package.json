{
  "name": "wasabi-sushi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma db push --skip-generate --accept-data-loss && next start -p ${PORT:-3000}",
    "lint": "next lint",
    "postinstall": "prisma generate || true",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "webp": "node scripts/to-webp.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  }
}
